@using TopDriveX.Application.Dtos
@model VehicleDto
@inject Microsoft.AspNetCore.Identity.UserManager<TopDriveX.Domain.Models.User> UserManager

@{
    ViewData["Title"] = $"{Model.MakeName} {Model.ModelName} {Model.Year}";
    var currentUserId = UserManager.GetUserId(User);
    var isOwner = currentUserId != null && Model.Id.ToString() == currentUserId;
    var isAdmin = User.IsInRole("Admin");
    var canEdit = isOwner || isAdmin;
}

<div class="bg-gray-50 min-h-screen py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Breadcrumb -->
        <nav class="mb-6">
            <ol class="flex items-center text-sm text-gray-500">
                <li><a asp-action="Index" class="hover:text-primary">Обяви</a></li>
                <li class="mx-2">/</li>
                <li class="text-gray-900">@Model.MakeName @Model.ModelName</li>
            </ol>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <!-- Left Column: Images & Details -->
            <div class="lg:col-span-2">

                <!-- Main Image -->
                <div class="bg-white rounded-xl shadow-lg overflow-hidden mb-6">
                    @if (Model.Images != null && Model.Images.Any())
                    {
                        <div class="relative">
                            <img id="mainImage" src="@Model.Images.First()" alt="@Model.MakeName @Model.ModelName"
                                 class="w-full h-96 object-cover"
                                 onerror="this.src='https://placehold.co/800x600/e5e7eb/6b7280?text=No+Image'">

                            <!-- Image Counter -->
                            <div class="absolute top-4 right-4 bg-black/70 text-white px-3 py-1 rounded-lg text-sm font-semibold">
                                <span id="currentImageIndex">1</span> / @Model.Images.Count
                            </div>
                        </div>

                        <!-- Thumbnail Gallery -->
                        @if (Model.Images.Count > 1)
                        {
                            <div class="p-4 bg-gray-50">
                                <div class="grid grid-cols-5 gap-2">
                                    @for (int i = 0; i < Model.Images.Count; i++)
                                    {
                                        <img src="@Model.Images[i]" alt="Thumbnail @(i+1)"
                                             onclick="changeMainImage('@Model.Images[i]', @(i+1))"
                                             class="cursor-pointer w-full aspect-video object-cover rounded-lg border-2 border-gray-200 hover:border-primary transition thumbnail @(i == 0 ? "border-primary" : "")">
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="w-full h-96 bg-gray-200 flex items-center justify-center">
                            <div class="text-center text-gray-500">
                                <svg class="w-24 h-24 mx-auto mb-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                                </svg>
                                <p class="text-lg font-semibold">Няма налични снимки</p>
                            </div>
                        </div>
                    }
                </div>

                <!-- Vehicle Details -->
                <div class="bg-white rounded-xl shadow-lg p-8 mb-6">
                    <h2 class="text-2xl font-bold text-gray-900 mb-6 pb-3 border-b border-gray-100">
                        📋 Технически характеристики
                    </h2>

                    <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
                        <div>
                            <p class="text-sm text-gray-500 mb-1">Година</p>
                            <p class="text-lg font-bold text-gray-900">@Model.Year</p>
                        </div>
                        <div>
                            <p class="text-sm text-gray-500 mb-1">Пробег</p>
                            <p class="text-lg font-bold text-gray-900">@Model.Mileage.ToString("N0") км</p>
                        </div>
                        <div>
                            <p class="text-sm text-gray-500 mb-1">Гориво</p>
                            <p class="text-lg font-bold text-gray-900">
                                @switch (Model.FuelType)
                                {
                                    case "Petrol":
                                        <text>Бензин</text>
                                        ; break;
                                    case "Diesel":
                                        <text>Дизел</text>
                                        ; break;
                                    case "Electric":
                                        <text>Електричество</text>
                                        ; break;
                                    case "Hybrid":
                                        <text>Хибрид</text>
                                        ; break;
                                    case "PlugInHybrid":
                                        <text>Plug-in хибрид</text>
                                        ; break;
                                    case "LPG":
                                        <text>ГАЗ (LPG)</text>
                                        ; break;
                                    case "CNG":
                                        <text>CNG</text>
                                        ; break;
                                    default:
                                        <text>@Model.FuelType</text>
                                        ; break;
                                }
                            </p>
                        </div>
                        <div>
                            <p class="text-sm text-gray-500 mb-1">Скоростна кутия</p>
                            <p class="text-lg font-bold text-gray-900">
                                @switch (Model.TransmissionType)
                                {
                                    case "Manual":
                                        <text>Ръчна</text>
                                        ; break;
                                    case "Automatic":
                                        <text>Автоматична</text>
                                        ; break;
                                    case "SemiAutomatic":
                                        <text>Полуавтоматична</text>
                                        ; break;
                                    case "CVT":
                                        <text>CVT</text>
                                        ; break;
                                    default:
                                        <text>@Model.TransmissionType</text>
                                        ; break;
                                }
                            </p>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Color))
                        {
                            <div>
                                <p class="text-sm text-gray-500 mb-1">Цвят</p>
                                <p class="text-lg font-bold text-gray-900">@Model.Color</p>
                            </div>
                        }
                        <div>
                            <p class="text-sm text-gray-500 mb-1">Град</p>
                            <p class="text-lg font-bold text-gray-900">@Model.City</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Price & Contact -->
            <div class="lg:col-span-1">

                <!-- Price Card -->
                <div class="bg-gradient-to-br from-red-600 to-red-800 rounded-xl shadow-2xl p-8 text-white sticky top-4 mb-6">
                    <h1 class="text-3xl font-bold mb-4">@Model.MakeName @Model.ModelName</h1>
                    <div class="text-5xl font-black mb-6">@Model.Price.ToString("N0") лв</div>

                    <div class="space-y-3 mb-6">
                        <div class="flex items-center text-red-100">
                            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                            </svg>
                            <span>@Model.Year г.</span>
                        </div>
                        <div class="flex items-center text-red-100">
                            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
                                <path d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3z" />
                            </svg>
                            <span>@Model.Mileage.ToString("N0") км</span>
                        </div>
                        <div class="flex items-center text-red-100">
                            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                            </svg>
                            <span>@Model.City</span>
                        </div>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="space-y-3">
                            <button onclick="alert('Функционалност за показване на телефон (скоро)')"
                                    class="w-full bg-white hover:bg-gray-100 text-red-600 py-3 rounded-lg font-bold transition shadow-lg">
                                📞 Покажи телефон
                            </button>
                            <button onclick="alert('Функционалност за любими (скоро)')"
                                    class="w-full bg-red-500 hover:bg-red-400 text-white py-3 rounded-lg font-bold transition">
                                ❤️ Запази в любими
                            </button>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path"
                           class="block w-full bg-white hover:bg-gray-100 text-red-600 py-3 rounded-lg font-bold transition shadow-lg text-center">
                            Влез за контакт
                        </a>
                    }
                </div>

                <!-- Owner/Admin Edit Buttons -->
                @if (User.Identity?.IsAuthenticated == true && canEdit)
                {
                    <div class="bg-gradient-to-r from-blue-50 to-purple-50 rounded-xl shadow-lg p-6 border-2 border-blue-200 mb-6">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-lg font-bold text-gray-900 flex items-center">
                                <svg class="w-6 h-6 text-blue-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
                                </svg>
                                @(isAdmin && !isOwner ? "Администраторски контрол" : "Управление на обявата")
                            </h3>
                            @if (isAdmin && !isOwner)
                            {
                                <span class="bg-yellow-100 text-yellow-800 text-xs px-3 py-1 rounded-full font-bold">
                                    ADMIN
                                </span>
                            }
                        </div>

                        <div class="flex gap-3">
                            <a asp-action="Edit" asp-route-id="@Model.Id"
                               class="flex-1 flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-bold transition shadow-md transform hover:scale-105">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                                </svg>
                                Редактирай
                            </a>

                            <button type="button" onclick="confirmDelete()"
                                    class="flex-1 flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-lg font-bold transition shadow-md transform hover:scale-105">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                                </svg>
                                Изтрий
                            </button>
                        </div>
                    </div>

                    <!-- Hidden Delete Form -->
                    <form id="deleteFormDetails" asp-action="Delete" asp-route-id="@Model.Id" method="post" class="hidden">
                        @Html.AntiForgeryToken()
                    </form>
                }

                <!-- Safety Notice -->
                <div class="bg-yellow-50 border-2 border-yellow-200 rounded-xl p-6">
                    <h3 class="font-bold text-yellow-900 mb-2 flex items-center">
                        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                        Внимание при покупка
                    </h3>
                    <p class="text-sm text-yellow-800">
                        Винаги проверявайте автомобила на място преди покупка.
                        TopDriveX не носи отговорност за транзакции между потребители.
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeMainImage(imageUrl, index) {
            document.getElementById('mainImage').src = imageUrl;
            document.getElementById('currentImageIndex').textContent = index;

            // Update thumbnail borders
            document.querySelectorAll('.thumbnail').forEach(thumb => {
                thumb.classList.remove('border-primary');
                thumb.classList.add('border-gray-200');
            });
            event.target.classList.remove('border-gray-200');
            event.target.classList.add('border-primary');
        }

        function confirmDelete() {
            if (confirm('⚠️ Сигурни ли сте, че искате да изтриете тази обява?\n\nТова действие е необратимо!')) {
                document.getElementById('deleteFormDetails').submit();
            }
        }
    </script>
}
