@using System.Security.Claims
@model TopDriveX.Application.Dtos.EditAdvertisementDto

@{
    ViewData["Title"] = "Редактирай обява";
}

<div class="bg-gray-50 min-h-screen py-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Header -->
        <div class="mb-8">
            <a asp-action="Details" asp-route-id="@Model.VehicleId" class="inline-flex items-center text-gray-600 hover:text-primary transition mb-4">
                <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                </svg>
                Назад към обявата
            </a>
            <h1 class="text-3xl font-bold text-gray-900">Редактирай обява</h1>
            <p class="text-gray-600 mt-2">Обнови информацията за автомобила</p>
        </div>

        <!-- Form -->
        <form asp-action="Edit" asp-route-id="@Model.AdvertisementId" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AdvertisementId" />
            <input type="hidden" asp-for="VehicleId" />
            <input type="hidden" asp-for="OwnerId" />
            <input type="hidden" asp-for="ImagesToDeleteJson" id="imagesToDeleteJson" />

            <!-- Vehicle Info -->
            <div class="bg-white rounded-xl shadow-lg p-8 mb-6">
                <h2 class="text-xl font-bold text-gray-900 mb-6 pb-3 border-b border-gray-100">
                    🚗 Информация за автомобила
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <!-- Make -->
                    <div>
                        <label asp-for="MakeId" class="block text-sm font-medium text-gray-700 mb-2">Марка *</label>
                        <select asp-for="MakeId" id="makeSelect"
                                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition">
                            <option value="">— Изберете марка —</option>
                            @if (ViewBag.Makes != null)
                            {
                                @foreach (var item in ViewBag.Makes as Microsoft.AspNetCore.Mvc.Rendering.SelectList)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="MakeId" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Model -->
                    <div>
                        <label asp-for="ModelId" class="block text-sm font-medium text-gray-700 mb-2">Модел *</label>
                        <select asp-for="ModelId" id="modelSelect"
                                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition">
                            <option value="">— Изберете модел —</option>
                        </select>
                        <span asp-validation-for="ModelId" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Year -->
                    <div>
                        <label asp-for="Year" class="block text-sm font-medium text-gray-700 mb-2">Година *</label>
                        <input asp-for="Year" type="number" min="1900" max="2030"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition">
                        <span asp-validation-for="Year" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Mileage -->
                    <div>
                        <label asp-for="Mileage" class="block text-sm font-medium text-gray-700 mb-2">Пробег (км) *</label>
                        <input asp-for="Mileage" type="number" min="0"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition">
                        <span asp-validation-for="Mileage" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Fuel Type -->
                    <div>
                        <label asp-for="FuelType" class="block text-sm font-medium text-gray-700 mb-2">Гориво *</label>
                        <select asp-for="FuelType" asp-items="ViewBag.FuelTypes"
                                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition">
                            <option value="">— Изберете —</option>
                        </select>
                        <span asp-validation-for="FuelType" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Transmission -->
                    <div>
                        <label asp-for="TransmissionType" class="block text-sm font-medium text-gray-700 mb-2">Скоростна кутия *</label>
                        <select asp-for="TransmissionType" asp-items="ViewBag.TransmissionTypes"
                                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition">
                            <option value="">— Изберете —</option>
                        </select>
                        <span asp-validation-for="TransmissionType" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- City -->
                    <div>
                        <label asp-for="City" class="block text-sm font-medium text-gray-700 mb-2">Град *</label>
                        <input asp-for="City" type="text"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition">
                        <span asp-validation-for="City" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Price -->
                    <div>
                        <label asp-for="Price" class="block text-sm font-medium text-gray-700 mb-2">Цена (лв) *</label>
                        <input asp-for="Price" type="number" min="1"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition">
                        <span asp-validation-for="Price" class="text-red-500 text-sm"></span>
                    </div>
                </div>
            </div>

            <!-- Ad Details -->
            <div class="bg-white rounded-xl shadow-lg p-8 mb-6">
                <h2 class="text-xl font-bold text-gray-900 mb-6 pb-3 border-b border-gray-100">
                    📝 Детайли на обявата
                </h2>

                <!-- Title -->
                <div class="mb-5">
                    <label asp-for="Title" class="block text-sm font-medium text-gray-700 mb-2">Заглавие *</label>
                    <input asp-for="Title" type="text" maxlength="150"
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition">
                    <span asp-validation-for="Title" class="text-red-500 text-sm"></span>
                </div>

                <!-- Description -->
                <div class="mb-5">
                    <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-2">Описание *</label>
                    <textarea asp-for="Description" rows="8" maxlength="5000"
                              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition resize-none"></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-sm"></span>
                </div>

                <!-- Is Negotiable -->
                <div class="flex items-center">
                    <input asp-for="IsNegotiable" type="checkbox" class="w-5 h-5 rounded text-primary border-gray-300 focus:ring-primary">
                    <label asp-for="IsNegotiable" class="ml-2 text-sm font-medium text-gray-700">Цената е договаряема</label>
                </div>
            </div>

            <!-- Images -->
            <div class="bg-white rounded-xl shadow-lg p-8 mb-6">
                <h2 class="text-xl font-bold text-gray-900 mb-6 pb-3 border-b border-gray-100">
                    📷 Снимки
                </h2>

                @if (Model.ExistingImages.Any())
                {
                    <div class="mb-6">
                        <p class="text-sm font-medium text-gray-700 mb-3">Налични снимки:</p>
                        <div id="imagesGrid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3">
                            @for (int i = 0; i < Model.ExistingImages.Count; i++)
                            {
                                var img = Model.ExistingImages[i];
                                <div class="relative group" data-image="@img">
                                    <img src="@img" class="w-full aspect-square object-cover rounded-lg border-2 border-gray-200">
                                    <button type="button"
                                            onclick="deleteImage('@img')"
                                            class="absolute top-2 right-2 bg-red-600 hover:bg-red-700 text-white rounded-full p-2 opacity-0 group-hover:opacity-100 transition">
                                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                                        </svg>
                                    </button>
                                    @if (i == 0)
                                    {
                                        <div class="absolute top-2 left-2 bg-primary text-white text-xs px-2 py-1 rounded">Главна</div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Upload New -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-3">Добави нови снимки:</label>
                    <input type="file" name="NewImages" multiple accept="image/*"
                           class="w-full px-4 py-3 border-2 border-dashed border-gray-300 rounded-lg hover:border-primary transition">
                    <p class="text-xs text-gray-500 mt-2">Макс. 15 снимки, до 10 МБ всяка</p>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex gap-4 mb-6">
                <button type="submit" class="flex-1 bg-primary hover:bg-secondary text-white py-4 rounded-lg font-bold text-lg transition shadow-md">
                    💾 Запази промените
                </button>
                <a asp-action="Details" asp-route-id="@Model.VehicleId"
                   class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-900 py-4 rounded-lg font-bold text-lg transition text-center">
                    Отказ
                </a>
            </div>

            <!-- Delete -->
            @if (User.IsInRole("Admin") || Model.OwnerId.ToString() == User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier))
            {
                <div class="bg-red-50 border border-red-200 rounded-xl p-6">
                    <h3 class="text-lg font-bold text-red-900 mb-2">⚠️ Опасна зона</h3>
                    <p class="text-sm text-red-700 mb-4">Изтриването на обявата е необратимо.</p>
                    <button type="button" onclick="confirmDelete()"
                            class="bg-red-600 hover:bg-red-700 text-white px-6 py-2 rounded-lg font-semibold transition">
                        Изтрий обявата
                    </button>
                </div>
            }
        </form>

        <!-- Delete Form -->
        <form id="deleteForm" asp-action="Delete" asp-route-id="@Model.AdvertisementId" method="post" class="hidden">
            @Html.AntiForgeryToken()
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let imagesToDelete = [];

        function deleteImage(url) {
            if (confirm('Изтрий тази снимка?')) {
                imagesToDelete.push(url);
                document.getElementById('imagesToDeleteJson').value = JSON.stringify(imagesToDelete);
                document.querySelector(`[data-image="${url}"]`).remove();
            }
        }

        function confirmDelete() {
            if (confirm('Сигурни ли сте? Това действие е необратимо!')) {
                document.getElementById('deleteForm').submit();
            }
        }

        // Make → Model AJAX
        document.getElementById('makeSelect')?.addEventListener('change', async function () {
            const sel = document.getElementById('modelSelect');
            sel.innerHTML = '<option value="">Зареждане...</option>';
            if (!this.value) { sel.innerHTML = '<option value="">— Първо марка —</option>'; return; }
            try {
                const r = await fetch(`/Vehicles/GetModelsByMake?makeId=${this.value}`);
                const data = await r.json();
                sel.innerHTML = '<option value="">— Изберете модел —</option>' +
                    data.map(m => `<option value="${m.id}">${m.name}</option>`).join('');
            } catch { sel.innerHTML = '<option value="">Грешка</option>'; }
        });
    </script>
}
